# Bigger client_max_body_size for any file uploads + longer proxy timeout
# (LLM calls can take 5-10s; default nginx timeout would 504 them).
files:
  "/etc/nginx/conf.d/proxy.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      client_max_body_size 10M;
      proxy_connect_timeout 60s;
      proxy_send_timeout    60s;
      proxy_read_timeout    60s;
