option_settings:
  aws:elasticbeanstalk:application:environment:
    PYTHONPATH: "/var/app/current"
    PORT: "8000"
    PYTHONUNBUFFERED: "1"
  aws:elasticbeanstalk:environment:proxy:
    ProxyServer: nginx
  aws:elasticbeanstalk:cloudwatch:logs:
    StreamLogs: "true"
    DeleteOnTerminate: "false"
    RetentionInDays: "7"

container_commands:
  01_prebake_kb:
    command: ". /var/app/venv/*/bin/activate && python scripts/prebake_kb.py || true"
    leader_only: true
